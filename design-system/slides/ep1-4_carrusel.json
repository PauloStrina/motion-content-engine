      ]
    },
    {
      "bg": "negro", "eyebrow": "Con quién no", "eyebrow_color": "aqua", "pager": "02 — 07",
      "blocks": [
        {"type": "lyon", "text": "Con el que está cómodo<br>elegimos no trabajar.", "size": 52, "color": "blanco", "mb": 34},
        {"type": "lyont", "text": "Quiere comprar una herramienta<br>y seguir operando igual.<br>Eso no es transformación: es una compra.", "size": 40, "color": "aqua"}
      ]
    },
    {
      "bg": "negro", "eyebrow": "Con quién sí", "eyebrow_color": "aqua", "pager": "03 — 07",
      "blocks": [
        {"type": "lyon", "text": "Elegimos al que llega incómodo.", "size": 52, "color": "blanco", "mb": 34},
        {"type": "lyont", "text": "Hizo todos los cambios que pudo<br>y siente que, en el fondo,<br>algo no se movió.", "size": 42, "color": "aqua"}
      ]
    },
    {
      "bg": "violeta", "eyebrow": "El giro", "eyebrow_color": "aqua", "pager": "04 — 07",
