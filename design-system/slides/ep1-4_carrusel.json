        {"type": "lyon", "text": "Cree que esa incomodidad<br>es una debilidad para esconder.", "size": 48, "color": "blanco", "mb": 34},
        {"type": "futura", "text": "ES AL REVÉS.", "size": 96, "lh": 92, "color": "blanco"},
        {"type": "lyont", "text": "Es lo más lúcido que tiene.", "size": 42, "color": "aqua", "mt": 40}
      ]
